# 在线千问入口。完全离线可留空，但切到 QWEN_ONLINE 时必须配置。
BL_KEY=
VISION_API_KEY=

# MySQL 使用宿主机或局域网内现有实例。
SPRING_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/aimed?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USERNAME=your_mysql_username
MYSQL_PASSWORD=your_mysql_password

# MongoDB 走 compose 内置服务，一般不需要改。
SPRING_DATA_MONGODB_URI=mongodb://mongodb:27017/chat_memory_db

# 本地 Ollama。Docker 容器通过 host.docker.internal 访问宿主机 Ollama。
LOCAL_CHAT_BASE_URL=http://host.docker.internal:11434
LOCAL_CHAT_MODEL_NAME=qwen2.5:3b
EMBEDDING_BASE_URL=http://host.docker.internal:11434
EMBEDDING_MODEL_NAME=bge-m3:latest
LOCAL_VISION_BASE_URL=http://host.docker.internal:11434
LOCAL_VISION_MODEL_NAME=qwen2.5vl:7b

# 本地知识库
KNOWLEDGE_BASE_STORAGE_DIR=/app/data/knowledge-base
KNOWLEDGE_BASE_BOOTSTRAP_ENABLED=true

# 可选调优
EMBEDDING_TIMEOUT=PT180S
LOCAL_CHAT_TIMEOUT=PT120S
LOCAL_VISION_TIMEOUT=PT240S

# 纯在线部署默认走千问在线，不依赖本地 Ollama。
# 如果你在 IDEA 里直接点击 Docker Compose 运行配置，
# 请把本文件复制为项目根目录下的 `.env`，JetBrains 会自动读取它。
# 你可以把百炼 API Key 放在本机 `.env` 中，或在启动 IDEA 前 export BL_KEY。
BL_KEY=
VISION_API_KEY=

# 在线模型开关
APP_PROVIDER_DEFAULT=QWEN_ONLINE
APP_PROVIDER_LOCAL_ENABLED=false
APP_PROVIDER_ONLINE_ENABLED=true
APP_EMBEDDING_LOCAL_ENABLED=false
APP_EMBEDDING_ONLINE_ENABLED=true

# 在线模型名
ONLINE_CHAT_MODEL_NAME=qwen3.5-plus
ONLINE_EMBEDDING_MODEL_NAME=text-embedding-v4
VISION_MODEL_NAME=qwen3.5-plus

# Web 端口
FRONTEND_PORT=80

# 独立 MariaDB / MySQL 对外暴露
MYSQL_HOST_PORT=13306
MYSQL_ROOT_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_DATABASE=aimed
MYSQL_APP_USERNAME=shark
MYSQL_APP_PASSWORD=CHANGE_ME_DB_PASSWORD

# 独立 MongoDB 对外暴露
MONGO_HOST_PORT=27018
MONGO_ROOT_USERNAME=shark
MONGO_ROOT_PASSWORD=CHANGE_ME_DB_PASSWORD

# 知识库与启动策略
KNOWLEDGE_BASE_BOOTSTRAP_ENABLED=true
KNOWLEDGE_BASE_STORAGE_DIR=/app/data/knowledge-base

# 可选超时
ONLINE_EMBEDDING_TIMEOUT=PT120S
VISION_TIMEOUT=PT120S

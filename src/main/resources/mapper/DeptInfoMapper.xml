<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.linkjb.aimed.mapper.DeptInfoMapper">

    <!-- 分页查询：支持拼音首字母部分模糊匹配，fk可匹配妇科(fk)/妇产科(fck) -->
    <select id="selectDeptPage" resultType="com.linkjb.aimed.entity.DeptInfo">
        SELECT * FROM dept_info
        <where>
            <if test="keyword != null and keyword != ''">
                <!-- 核心匹配规则：拼音编码包含关键词 或 科室名称包含关键词 -->
                AND (pinyin_code LIKE CONCAT('%', #{keyword}, '%') OR dept_name LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY sort ASC, create_time DESC
    </select>

    <!-- 查询所有启用的科室，用于树形结构组装 -->
    <select id="selectAllEnableDept" resultType="com.linkjb.aimed.entity.DeptInfo">
        SELECT * FROM dept_info WHERE status = 1 ORDER BY sort ASC, create_time DESC
    </select>

</mapper>